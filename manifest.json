{
  "action": {
    "default_icon": {
      "128": "images/logo.png",
      "16": "images/logo.png",
      "48": "images/logo.png"
    },
    "default_title": "Pi Post Saver"
  },
  "background": {
    "service_worker": "extensions/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": ["extensions/content-script.js"],
      "matches": [
        "https://www.facebook.com/*",
        "https://facebook.com/*",
        "https://web.facebook.com/*",
        "https://m.facebook.com/*",
        "https://www.instagram.com/*",
        "https://instagram.com/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "description": "Download Social Media posts, including text, images, and videos.",
  "icons": {
    "128": "images/logo.png",
    "16": "images/logo.png",
    "48": "images/logo.png"
  },
  "key": "",
  "manifest_version": 3,
  "name": "Social Post Downloader",
  "permissions": ["downloads"],
  "update_url": "https://clients2.google.com/service/update2/crx",
  "version": "0.1.4",
  "web_accessible_resources": [
    {
      "matches": [
        "https://*.facebook.com/*",
        "https://*.instagram.com/*",
        "https://facebook.com/*",
        "https://instagram.com/*"
      ],
      "resources": [
        "extensions/*.js",
        "extensions/facebook/*.js",
        "extensions/instagram/*.js",
        "node_modules/umd-react/dist/*.js"
      ]
    }
  ]
}
